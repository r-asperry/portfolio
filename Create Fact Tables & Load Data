--CREATE FACT TABLE 1 - DONE
CREATE OR REPLACE TABLE FACT_SRCSALESTARGET
(
    DIMSTOREID NUMBER(38) CONSTRAINT FK_DIMSTOREID FOREIGN KEY REFERENCES DIM_STORE(DIMSTOREID)
    ,DIMRESELLERID NUMBER(38) CONSTRAINT FK_DIMRESELLERID FOREIGN KEY REFERENCES DIM_RESELLER(DIMRESELLERID)
    ,DIMTARGETDATEID NUMBER(9) CONSTRAINT FK_DIMTARGETDATEID FOREIGN KEY REFERENCES DIM_DATE(DATE_PKEY)
    ,DIMCHANNELID NUMBER(38) CONSTRAINT FK_DIMCHANNELID FOREIGN KEY REFERENCES DIM_CHANNEL(DIMCHANNELID)
    ,SALESTARGETAMOUNT VARCHAR(255) NOT NULL
);

--INSERT VALUES INTO FACT TABLE 1 - DONE
INSERT INTO FACT_SRCSALESTARGET 
(
    DIMSTOREID
    ,DIMRESELLERID
    ,DIMTARGETDATEID
    ,DIMCHANNELID
    ,SALESTARGETAMOUNT
)
SELECT DISTINCT
    NVL(DIM_STORE.DIMSTOREID,-1) AS DIMSTOREID,
    NVL(DIM_RESELLER.DIMRESELLERID,-1) AS DIMRESELLERID,
    DIM_DATE.DATE_PKEY AS DIMTARGETDATEID,
    NVL(DIM_CHANNEL.DIMCHANNELID,-1) AS DIMCHANNELID,
    (STAGE_TARGETDATACHANNELRESELLERSTORE.TARGETSALESAMOUNT) AS SALESTARGETAMOUNT  --CALCULATING DAILY TARGETS PER STORE/CHANNEL/RESELLER
    FROM STAGE_TARGETDATACHANNELRESELLERSTORE 
    INNER JOIN DIM_CHANNEL ON STAGE_TARGETDATACHANNELRESELLERSTORE.CHANNELNAME = DIM_CHANNEL.CHANNELNAME
    INNER JOIN DIM_DATE ON STAGE_TARGETDATACHANNELRESELLERSTORE.YEAR = DIM_DATE.YEAR 
    LEFT JOIN DIM_STORE ON STAGE_TARGETDATACHANNELRESELLERSTORE.TARGETNAME = DIM_STORE.STORENAME 
    LEFT JOIN DIM_RESELLER ON STAGE_TARGETDATACHANNELRESELLERSTORE.TARGETNAME = DIM_RESELLER.RESELLERNAME;

--CREATE FACT TABLE 2 - DONE
CREATE OR REPLACE TABLE FACT_PRODUCTSALESTARGET
(
    DIMPRODUCTID NUMBER(38) CONSTRAINT FK_DIMPRODUCTID FOREIGN KEY REFERENCES DIM_PRODUCT(DIMPRODUCTID)
    ,DIMTARGETDATEID NUMBER(9) CONSTRAINT FK_DIMTARGETDATEID FOREIGN KEY REFERENCES DIM_DATE(DATE_PKEY)
    ,PRODUCTTARGETSALESQUANTITY VARCHAR(255) NOT NULL
);

--INSERT VALUES INTO FACT TABLE 2 - DONE
INSERT INTO FACT_PRODUCTSALESTARGET 
(
    DIMPRODUCTID
    ,DIMTARGETDATEID
    ,PRODUCTTARGETSALESQUANTITY
)
SELECT 
    NVL(DIM_PRODUCT.DIMPRODUCTID,-1) AS DIMPRODUCTID
    ,DIM_DATE.DATE_PKEY AS DIMTARGETDATEID
    ,(STAGE_TARGETDATAPRODUCT.SALESQUANTITYTARGET) AS PRODUCTTARGETSALESQUANTITY --CALCULATING DAILY TARGETS PER PRODUCT
    FROM DIM_PRODUCT
    JOIN STAGE_TARGETDATAPRODUCT ON DIM_PRODUCT.PRODUCTID = STAGE_TARGETDATAPRODUCT.PRODUCTID
    JOIN DIM_DATE ON STAGE_TARGETDATAPRODUCT.YEAR = DIM_DATE.YEAR

--CREATE FACT TABLE 3
CREATE OR REPLACE TABLE FACT_SALESACTUALS
(
    DIMPRODUCTID NUMBER(38) CONSTRAINT FK_DIMPRODUCTID FOREIGN KEY REFERENCES DIM_PRODUCT(DIMPRODUCTID) --Foreign Key
    ,DIMSTOREID NUMBER(38) CONSTRAINT FK_DIMSTOREID FOREIGN KEY REFERENCES DIM_STORE(DIMSTOREID) --Foreign Key
    ,DIMRESELLERID NUMBER(38) CONSTRAINT FK_DIMRESELLERID FOREIGN KEY REFERENCES DIM_RESELLER(DIMRESELLERID) --Foreign Key
    ,DIMCUSTOMERID NUMBER(38) CONSTRAINT FK_DIMCUSTOMERID FOREIGN KEY REFERENCES DIM_CUSTOMER(DIMCUSTOMERID) --Foreign Key
    ,DIMCHANNELID NUMBER(38) CONSTRAINT FK_DIMCHANNELID FOREIGN KEY REFERENCES DIM_CHANNEL(DIMCHANNELID) --Foreign Key
    ,DIMSALESDATEID NUMBER(9) CONSTRAINT FK_DIMSALESDATEID FOREIGN KEY REFERENCES DIM_DATE(DATE_PKEY) --Foreign Key
    ,DIMLOCATIONID NUMBER(38) CONSTRAINT FK_DIMLOCATIONID FOREIGN KEY REFERENCES DIM_LOCATION(DIMLOCATIONID) --Foreign Key
    ,SALESHEADERID NUMBER(38)
    ,SALESDETAILID NUMBER(38)
    ,SALEAMOUNT FLOAT
    ,SALEQUANTITY FLOAT
    ,SALEUNITPRICE FLOAT
    ,SALEEXTENDEDCOST FLOAT
    ,SALETOTALPROFIT FLOAT
);

--INSERT VALUES INTO FACT TABLE 3 - DONE
INSERT INTO FACT_SALESACTUALS
(
    DIMPRODUCTID
    ,DIMSTOREID
    ,DIMRESELLERID
    ,DIMCUSTOMERID
    ,DIMCHANNELID
    ,DIMSALESDATEID
    ,DIMLOCATIONID
    ,SALESHEADERID
    ,SALESDETAILID 
    ,SALEAMOUNT
    ,SALEQUANTITY
    ,SALEUNITPRICE
    ,SALEEXTENDEDCOST
    ,SALETOTALPROFIT
)
SELECT  
    STAGE_SALESDETAIL.PRODUCTID AS DIMPRODUCTID
    ,NVL(DIM_STORE.DIMSTOREID,-1) AS DIMSTOREID
    ,NVL(DIM_RESELLER.DIMRESELLERID,-1) AS DIMRESELLERID
    ,NVL(DIM_CUSTOMER.DIMCUSTOMERID, -1) AS DIMCUSTOMERID
    ,NVL(STAGE_SALESHEADER.CHANNELID,-1) AS DIMCHANNELID
    ,DIM_DATE.DATE_PKEY AS DIMSALESDATEID
    ,NVL(DIM_LOCATION.DIMLOCATIONID,-1) AS DIMLOCATIONID
    ,NVL(STAGE_SALESDETAIL.SALESHEADERID,-1) AS SALESHEADERID 
    ,NVL(STAGE_SALESDETAIL.SALESDETAILID, -1) AS SALESDETAILID
    ,STAGE_SALESDETAIL.SALESAMOUNT AS SALESAMOUNT
    ,STAGE_SALESDETAIL.SALESQUANTITY AS SALESQUANTITY
    ,DIM_PRODUCT.PRODUCTRETAILPRICE AS SALEUNITPRICE 
    ,(DIM_PRODUCT.PRODUCTCOST * STAGE_SALESDETAIL.SALESQUANTITY) As SALEEXTENDEDCOST
    ,(STAGE_SALESDETAIL.SALESAMOUNT - SALEEXTENDEDCOST) AS SALETOTALPROFIT
FROM STAGE_SALESDETAIL
JOIN STAGE_SALESHEADER ON STAGE_SALESDETAIL.SALESHEADERID = STAGE_SALESHEADER.SALESHEADERID
INNER JOIN DIM_DATE ON DIM_DATE.DATE = STAGE_SALESHEADER.DATE
INNER JOIN DIM_PRODUCT ON DIM_PRODUCT.PRODUCTID = STAGE_SALESDETAIL.PRODUCTID
LEFT JOIN DIM_STORE ON STAGE_SALESHEADER.STOREID = DIM_STORE.DIMSTOREID
LEFT JOIN DIM_RESELLER ON STAGE_SALESHEADER.RESELLERID = DIM_RESELLER.RESELLERID 
INNER JOIN DIM_CUSTOMER ON STAGE_SALESHEADER.CUSTOMERID = DIM_CUSTOMER.CUSTOMERID
INNER JOIN DIM_CHANNEL ON STAGE_SALESHEADER.CHANNELID = DIM_CHANNEL.CHANNELID
JOIN DIM_LOCATION ON DIM_LOCATION.DIMLOCATIONID = DIM_STORE.DIMLOCATIONID 
    OR DIM_LOCATION.DIMLOCATIONID = DIM_RESELLER.DIMLOCATIONID 
    OR DIM_LOCATION.DIMLOCATIONID = DIM_CUSTOMER.DIMLOCATIONID
    
