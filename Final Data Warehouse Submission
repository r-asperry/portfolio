/* THREE CUSTOM VIEWS TO ANSWER THE ASSIGNMENT QUESTIONS */
CREATE OR REPLACE SECURE VIEW GOALBYSTATEVIEW AS
SELECT 
    DIM_LOCATION.STATEPROVINCE
    ,DIM_DATE.YEAR
    ,sum(SALESTARGETAMOUNT) AS SALESTARGETAMOUNT
FROM FACT_SRCSALESTARGET
LEFT JOIN DIM_STORE ON DIM_STORE.DIMSTOREID = FACT_SRCSALESTARGET.DIMSTOREID
JOIN DIM_LOCATION ON DIM_LOCATION.DIMLOCATIONID = DIM_STORE.DIMLOCATIONID
LEFT JOIN DIM_DATE ON DIM_DATE.DATE_PKEY = FACT_SRCSALESTARGET.DIMTARGETDATEID
WHERE DIMTARGETDATEID = '20130101' OR DIMTARGETDATEID = '20140101'
GROUP BY DIM_LOCATION.STATEPROVINCE, DIM_DATE.YEAR

/* STORE PERFORMANCE BY STATE BY YEAR */
CREATE OR REPLACE SECURE VIEW PERFORMANCEBYSTATEVIEW AS
SELECT
    DIM_LOCATION.STATEPROVINCE
    ,DIM_DATE.YEAR
    ,sum(FACT_SALESACTUALS.SALETOTALPROFIT) AS SUMSTORESALEPROFIT
FROM FACT_SALESACTUALS
LEFT JOIN DIM_STORE ON DIM_STORE.DIMSTOREID = FACT_SALESACTUALS.DIMSTOREID
LEFT JOIN DIM_LOCATION ON DIM_LOCATION.DIMLOCATIONID = FACT_SALESACTUALS.DIMLOCATIONID
LEFT JOIN DIM_DATE ON DIM_DATE.DATE_PKEY = FACT_SALESACTUALS.DIMSALESDATEID
GROUP BY DIM_LOCATION.STATEPROVINCE, DIM_DATE.YEAR;

/* STATES WITH MULTIPLE STORES */
CREATE OR REPLACE SECURE VIEW STATESTORECOUNT AS
SELECT
    STATEPROVINCE
    ,COUNT(DIMSTOREID) AS NUMBEROFSTORES
FROM DIM_LOCATION
JOIN DIM_STORE ON DIM_STORE.DIMLOCATIONID = DIM_LOCATION.DIMLOCATIONID
GROUP BY STATEPROVINCE


/* FINISHED */
--CREATE AGGREGATE VIEWS FOR VIZUALIZATION PREP - QUESTION 1 - STORE PERFORMANCE TO GOAL
/* GOAL PERFORMANCE */
CREATE OR REPLACE SECURE VIEW STOREGOALVIEW AS
SELECT
    DIM_STORE.STORENUMBER
    ,DIM_DATE.YEAR
    ,AVG(FACT_SRCSALESTARGET.SALESTARGETAMOUNT) AS SALESTARGETAMOUNT
FROM FACT_SRCSALESTARGET
LEFT JOIN DIM_STORE ON DIM_STORE.DIMSTOREID = FACT_SRCSALESTARGET.DIMSTOREID
LEFT JOIN DIM_DATE ON DIM_DATE.DATE_PKEY = FACT_SRCSALESTARGET.DIMTARGETDATEID
WHERE (DIM_STORE.STORENUMBER = '5' OR DIM_STORE.STORENUMBER = '8') AND (DIM_DATE.YEAR = '2013'  OR DIM_DATE.YEAR = '2014')
GROUP BY DIM_STORE.STORENUMBER, DIM_DATE.YEAR;

/* ACTUAL PERFORMANCE */
CREATE OR REPLACE SECURE VIEW STOREPERFORMANCEVIEW AS
SELECT
    DIM_STORE.STORENUMBER
    ,DIM_DATE.YEAR
    ,SUM(SALETOTALPROFIT) AS SALETOTALPROFIT
FROM FACT_SALESACTUALS
LEFT JOIN DIM_STORE ON DIM_STORE.DIMSTOREID = FACT_SALESACTUALS.DIMSTOREID
LEFT JOIN DIM_DATE ON FACT_SALESACTUALS.DIMSALESDATEID = DIM_DATE.DATE_PKEY
WHERE (DIM_STORE.STORENUMBER = '5' OR DIM_STORE.STORENUMBER = '8')
GROUP BY DIM_STORE.STORENUMBER, DIM_DATE.YEAR;

/* FINISHED */
--CREATE AGGREGATE VIEWS FOR VISUALIZATION PREP - QUESTION 3 - SALES BY DAY OF WEEK
CREATE OR REPLACE SECURE VIEW SALESBYDAYOFWEEK AS
SELECT
    DIM_STORE.STORENUMBER
    ,DIM_DATE.DAY_NAME
    ,AVG(SALEAMOUNT) AS SALEAMOUNT
    ,AVG(SALEEXTENDEDCOST) AS SALEEXTENDEDCOST
    ,AVG(SALETOTALPROFIT) AS SALETOTALPROFIT
FROM FACT_SALESACTUALS
LEFT JOIN DIM_DATE ON DIMSALESDATEID = DATE_PKEY
LEFT JOIN DIM_STORE ON DIM_STORE.DIMSTOREID = FACT_SALESACTUALS.DIMSTOREID
WHERE DIM_STORE.STORENUMBER = '8' OR DIM_STORE.STORENUMBER = '5'
GROUP BY DAY_NAME, DIM_STORE.STORENUMBER

--CREATE AGGREGATE VIEWS FOR VISUALIZATION PREP - QUESTION 3 - DAILY GOAL SALES
CREATE OR REPLACE SECURE VIEW DAILYGOALS AS
SELECT
    DIM_STORE.STORENUMBER
    ,AVG(SALESTARGETAMOUNT / 365) AS DAILYGOAL
FROM FACT_SRCSALESTARGET
JOIN DIM_STORE ON DIM_STORE.DIMSTOREID = FACT_SRCSALESTARGET.DIMSTOREID
WHERE DIM_STORE.STORENUMBER = '8' OR DIM_STORE.STORENUMBER = '5'
GROUP BY DIM_STORE.STORENUMBER

